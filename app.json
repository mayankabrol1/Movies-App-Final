{
  "expo": {
    "name": "Movie App",
    "owner": "andromeda156",
    "slug": "movie-app",
    "scheme": "movieapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.andromeda156.movieapp"
    },
    "android": {
      "package": "com.andromeda156.movieapp",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Movie App to access your photos so you can choose a profile picture."
        }
      ]
    ]
  }
}
